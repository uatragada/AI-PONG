# Local production-ish defaults. Copy to .env or set these in your host dashboard.
NODE_ENV=production
PORT=8787

# Set this to your real deployed origin before sharing publicly.
# Example: https://pong.yourdomain.com
AIPONG_ALLOWED_ORIGIN=http://localhost:8787

# Local disk is fine for a single persistent server.
# Use "r2" later when you add Cloudflare R2 credentials.
AIPONG_STORAGE=local
AIPONG_DATA_DIR=./data

# Upload limits for 10 Hz, one-minute .aipong chunks.
AIPONG_MAX_UPLOAD_BYTES=150000
AIPONG_MAX_SAMPLES_PER_UPLOAD=700
AIPONG_MIN_TRAJECTORY_SAMPLES=120
AIPONG_MIN_TRAJECTORY_DURATION_MS=20000
AIPONG_MIN_INPUT_CHANGES=4
AIPONG_MIN_HUMAN_HITS=1
AIPONG_MIN_VISIBLE_RATIO=0.8
AIPONG_MAX_PONG_SCORE=7

# Per-IP limits per window. Put Cloudflare rate limiting in front of this too.
AIPONG_RATE_LIMIT_WINDOW_MS=60000
AIPONG_TRAJECTORY_RATE_LIMIT=30
AIPONG_LEADERBOARD_RATE_LIMIT=12
AIPONG_STATS_RATE_LIMIT=30

# Optional usage budget guardrail. Set AIPONG_USAGE_BUDGET_UNITS to 0 to disable.
# Defaults slow the site before the cap and switch the home page to maintenance at 80%.
AIPONG_USAGE_BUDGET_UNITS=0
AIPONG_USAGE_WINDOW=monthly
AIPONG_USAGE_SLOWDOWN_RATIO=0.65
AIPONG_USAGE_MAINTENANCE_RATIO=0.8
AIPONG_USAGE_BYTES_PER_UNIT=25000
AIPONG_USAGE_TRAJECTORY_BASE_UNITS=1
AIPONG_USAGE_PLAY_UNITS=1
AIPONG_USAGE_LEADERBOARD_UNITS=1
AIPONG_USAGE_MIN_SLOWDOWN_MS=250
AIPONG_USAGE_MAX_SLOWDOWN_MS=2500
AIPONG_USAGE_RETRY_AFTER_SECONDS=900

# Set to 1 only when the app is behind Cloudflare or another trusted proxy.
AIPONG_TRUST_PROXY_HEADERS=0

# Leaderboard.
AIPONG_LEADERBOARD_LIMIT=25
AIPONG_LEADERBOARD_MIN_DURATION_MS=5000

# Keep off publicly unless you are diagnosing a deployment.
AIPONG_EXPOSE_HEALTH_DETAILS=0

# Cloudflare R2, optional for later.
# AIPONG_STORAGE=r2
# AIPONG_R2_ACCOUNT_ID=your-cloudflare-account-id
# AIPONG_R2_BUCKET=your-r2-bucket-name
# AIPONG_R2_ACCESS_KEY_ID=your-r2-access-key-id
# AIPONG_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# AIPONG_R2_PREFIX=ai-pong-training
