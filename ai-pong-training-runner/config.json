{
  "data_dir": "../ai-pong-human-training-site/data/trajectories",
  "base_model": "../ai-pong-human-training-site/web/models/current-policy.json",
  "model_dir": "../ai-pong-human-training-site/web/models",
  "r2": {
    "enabled": false,
    "bucket": "your-r2-bucket-name",
    "prefix": "ai-pong-training/trajectories",
    "endpoint_url": "https://your-account-id.r2.cloudflarestorage.com"
  },
  "training": {
    "device": "auto",
    "seed": 7,
    "epochs": 12,
    "batch_size": 512,
    "learning_rate": 0.0003,
    "class_balance": true,
    "class_weight_power": 1.0,
    "validation_fraction": 0.1,
    "max_samples": 1000000,
    "min_files": 5,
    "min_samples": 5000
  },
  "eval": {
    "min_validation_accuracy": 0.38,
    "min_prediction_entropy": 0.2,
    "max_stay_prediction_fraction": 0.75,
    "max_single_action_fraction": 0.85
  },
  "promotion": {
    "enabled": true,
    "promote_to": "../ai-pong-human-training-site/web/models/current-policy.json",
    "keep_versioned_copy": true
  }
}
